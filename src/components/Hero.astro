---
import { Download, ExternalLink, Languages, Mail } from "@lucide/astro";
import type { Lang } from "../lib/resume";
import { localized, resumeData, withBase } from "../lib/resume";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const content = localized(lang);
const primaryPdf = lang === "zh" ? "/files/Yi-Li-Chiu-CV-zh.pdf" : "/files/Yi-Li-Chiu-CV-en.pdf";
const alternateHref = lang === "zh" ? "/" : "/zh/";
const introLabel = lang === "zh" ? "你好，我是" : "HELLO, MY NAME IS";
---

<section class="hero">
  <div class="hero__shape" aria-hidden="true"></div>
  <div class="hero__inner">
    <div class="hero__content">
      <p class="hero__name">{introLabel}</p>
      <h1>{resumeData.contact.name[lang]}</h1>
      <p class="hero__role">{content.hero.role}</p>
      <p class="hero__summary">{content.hero.summary}</p>
      <div class="hero__contact" aria-label="Contact">
        <a href={`mailto:${resumeData.contact.email}`}>
          <Mail size={18} stroke-width={2.5} aria-hidden="true" />
          <span>{resumeData.contact.email}</span>
        </a>
        <a href={resumeData.contact.github.url} target="_blank" rel="noreferrer">
          <ExternalLink size={18} stroke-width={2.5} aria-hidden="true" />
          <span>{resumeData.contact.github.label}</span>
        </a>
      </div>
      <div class="hero__actions">
        <a class="button button--primary" href={withBase(primaryPdf)}>
          <Download size={18} stroke-width={2} />
          <span>{content.hero.primaryCta}</span>
        </a>
        <a class="button" href={withBase(alternateHref)}>
          <Languages size={18} stroke-width={2} />
          <span>{content.hero.secondaryCta}</span>
        </a>
      </div>
      <ul class="hero__highlights">
        {content.hero.highlights.map((highlight) => <li>{highlight}</li>)}
      </ul>
    </div>
    <div class="hero__portrait-wrap" aria-hidden="true">
      <img class="hero__portrait" src={withBase("/images/profile-yili.jpg")} alt="" />
    </div>
  </div>
</section>
